<Window x:Class="Shop.AddEditOrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Shop"
        mc:Ignorable="d" Style="{StaticResource Windows}"
        Title="Добавление/Редактирование заказа" Height="450" Width="800">
    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <ScrollViewer>
            <StackPanel Margin="20 0">
                <TextBlock Text="Артикул"  Margin="0 10 0 5"/>
                <TextBox x:Name="ReceptCode" MaxLength="50"/>

                <TextBlock Text="Статус заказа"  Margin="0 10 0 5"/>
                <ComboBox x:Name="OrderStatus" DisplayMemberPath="Name" SelectedValuePath="Id"/>

                <TextBlock Text="Пункт выдачи"  Margin="0 10 0 5"/>
                <ComboBox x:Name="PickUpPoint" SelectedValuePath="Id">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock>
                         <Run Text="{Binding PostCode}"/>
                         <Run Text=", "/>
                         <Run Text="{Binding City}"/>
                         <Run Text=", "/>
                         <Run Text="{Binding Street}"/>
                         <Run Text=", "/>
                         <Run Text="{Binding Building}"/>
                            </TextBlock>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBlock Text="Дата заказа"  Margin="0 10 0 5"/>
                <DatePicker x:Name="CreationDate"/>

                <TextBlock Text="Дата выдачи"  Margin="0 10 0 5"/>
                <DatePicker x:Name="DeliveriDate"/>

                <TextBlock Text="Клиент"  Margin="0 10 0 5"/>
                <ComboBox x:Name="OrderUser" DisplayMemberPath="Suname" SelectedValuePath="Id"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Button x:Name="CencelButton" Content="Отменить" Width="100" Height="35" Margin="10 0" Click="CencelButton_Click"/>
            <Button x:Name="DeleteButton" Content="Удалить" Width="100" Height="35" Margin="10 0" Click="DeleteButton_Click" Background="Red" Foreground="White" Visibility="Collapsed"/>
            <Button x:Name="SaveButton" Content="Сохранить" Width="100" Height="35" Margin="10 0" Click="SaveButton_Click"/>
        </StackPanel>


    </Grid>
</Window>
