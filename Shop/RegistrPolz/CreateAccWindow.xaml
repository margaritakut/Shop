<Window x:Class="Shop.RegistrPolz.CreateAccWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Shop.RegistrPolz"
        mc:Ignorable="d" Style="{StaticResource ResourceKey=Windows}"
        Title="Регистрация" Height="450" Width="800">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <StackPanel Orientation="Horizontal" Margin="5">
                <TextBlock Text="Имя:" Width="100"/>
                <TextBox x:Name="txbName" Width="200"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="5">
                <TextBlock Text="Логин:" Width="100"/>
                <TextBox x:Name="txbLogin" Width="200"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="5">
                <TextBlock Text="Пароль:" Width="100"/>
                <TextBox x:Name="txbPass" Width="200"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="5">
                <TextBlock Text="Подтверждение пароля:" Width="100"/>
                <PasswordBox x:Name="psbPass" Width="200" PasswordChanged="psbPass_PasswordChanged"/>
            </StackPanel>
            <Button x:Name="btnCreate" Content="Создать" Click="btnCreate_Click" IsEnabled="False" Margin="5"/>
            <Button x:Name="btnBack" Content="Назад" Click="btnBack_Click" Margin="5"/>
        </StackPanel>

    </Grid>
</Window>
