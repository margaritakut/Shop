<Window x:Class="Shop.OrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Shop"
        mc:Ignorable="d" Style="{StaticResource Windows}"
        Title="Управление заказами" Height="800" Width="1200">
    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <Grid HorizontalAlignment="Left" Name="AdminPanel">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <StackPanel Margin="20 0" Grid.Column="0">
                <TextBlock Text="Поиск"/>
                <TextBox Name="SearchingTextBox" Width="200" TextChanged="SearchingTextBox_TextChanged"/>
            </StackPanel>

            <StackPanel Margin="20 0" Grid.Column="1">
                <TextBlock Text="Сортировка"/>
                <ComboBox Name="SortingComBox" Width="200" SelectionChanged="SortingComBox_SelectionChanged"/>
            </StackPanel>

            <StackPanel Margin="20 0" Grid.Column="2">
                <TextBlock Text="Фильтрация по статусу"/>
                <ComboBox Name="FilteringComBox" Width="200" SelectionChanged="FilteringComBox_SelectionChanged"/>
            </StackPanel>

        </Grid>

        <TextBlock Name="FullUserName" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="20 10"/>

        <ScrollViewer Grid.Row="1">
            <ItemsControl x:Name="OrderList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="10 "
                         Tag="{Binding Id}"
                         Background="{Binding Background}"
                         MouseDown="Border_MouseDown"
                         BorderBrush="Gray" 
                         BorderThickness="1" 
                         CornerRadius="5">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Артикул заказа " FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding ReceptCode}"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Статус заказа: "/>
                                        <TextBlock Text="{Binding OrderStatus.Name}"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Адрес пункта выдачи: "/>
                                        <TextBlock>
                                     <Run Text="{Binding PickUpPoint.PostCode}"/>
                                     <Run Text="{Binding PickUpPoint.City}"/>
                                     <Run Text="{Binding PickUpPoint.Street}"/>
                                     <Run Text="{Binding PickUpPoint.Building}"/>
                                        </TextBlock>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Дата заказа: "/>
                                        <TextBlock Text="{Binding CreationDate, 
                                     StringFormat=dd.MM.yyyy}"/>
                                    </StackPanel>
                                </StackPanel>

                                <Border Grid.Column="1">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Дата доставки  "/>
                                        <TextBlock Text="{Binding DeliveriDate, 
                                     StringFormat=dd.MM.yyyy }"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Button Name="BackButton" Content="Назад к товарам" Grid.Row="2" VerticalAlignment="Center" 
         HorizontalAlignment="Left" Margin="20 0" Click="BackButton_Click"/>

        <Button Name="CreateButton" Content="Добавить заказ" Grid.Row="2" VerticalAlignment="Center" 
         HorizontalAlignment="Right" Margin="20 0" Click="CreateButton_Click" Visibility="Collapsed"/>

    </Grid>
</Window>
