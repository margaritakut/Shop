<Window x:Class="Shop.AddEditProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Shop"
        mc:Ignorable="d" Style="{StaticResource Windows}"
        Title="Редоктирование данных о продукте" Height="450" Width="800">
    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <ScrollViewer>
            <StackPanel Margin="20 0">
                <TextBlock Text="Артикул"/>
                <TextBox x:Name="ProductArticle" 
                   MaxLength="10"/>


                <TextBlock Text="Наименование"/>
                <TextBox x:Name="ProductName" 
                    MaxLength="30"/>

                <TextBlock Text="Единица измерения"/>
                <ComboBox Name="ProductUnit"/>

                <TextBlock Text="Цена"/>
                <TextBox Name="ProductPrice" />

                <TextBlock Text="Производитель"/>
                <ComboBox Name="ProductProducer"/>

                <TextBlock Text="Поставщик"/>
                <ComboBox Name="ProductProvider"/>

                <TextBlock Text="Категория"/>
                <ComboBox Name="ProductCategory"/>

                <TextBlock Text="Скидка"/>
                <TextBox Name="ProductDiscount" />

                <TextBlock Text="Количество на складе"/>
                <TextBox Name="ProductAmountInStock" />

                <TextBlock Text="Описание"/>
                <TextBox Name="ProductDescription" 
                 Height="150"
                 TextWrapping="Wrap"/>

                <TextBlock Text="Фото"/>
                <TextBox Name="ProductPhoto" />

            </StackPanel>
        </ScrollViewer>

        <Button Name="CencelButton" 
        Content="Отминить"
        Grid.Row="1"
        HorizontalAlignment="Left"
        VerticalAlignment="Center"
        Margin="20 0"
        Click="CencelButton_Click"/>

        <Button Name="SaveButton" 
          Content="Сохранить"
          Grid.Row="1"
          HorizontalAlignment="Right"
          VerticalAlignment="Center"
          Margin="20 0"
          Click="SaveButton_Click"/>
        
        <Button Name="DeleteButton" Content="Удалить" Grid.Row="2" 
        HorizontalAlignment="Center" VerticalAlignment="Center" 
        Width="100" Height="35" Margin="200 0" 
        Click="DeleteButton_Click" Background="Red" Foreground="White"
        Visibility="Collapsed"/>

    </Grid>
</Window>
